)
)
)
grid.arrange(
p,
table_grob,
ncol = 1,
heights = c(4, 1.4)
)
# ---------------------------
# Load Libraries
# ---------------------------
library(tidyverse)
library(gridExtra)
library(grid)
categories <- c(
"Exploring AI Vendors\nor Service Providers",
"Processes for Ethical\n& Legal AI Use",
"Confidence in AI Benefits\nOutweighing Risks",
"ETV"
)
# Yes = International
international_scores <- c(4.48, 4.59, 4.87, 4.6667)
# No = Domestic
domestic_scores <- c(3.69, 3.69, 4.26, 3.8977)
# Total = Average
avg_scores <- c(3.92, 3.96, 4.44, 4.1273)
df <- data.frame(
Category = factor(categories, levels = categories),
International = international_scores,
Domestic = domestic_scores,
Average = avg_scores
)
# Reshape for plotting
df_long <- df %>%
pivot_longer(
cols = c("International", "Domestic"),
names_to = "Group",
values_to = "Score"
)
p <- ggplot(df_long, aes(x = Category, y = Score)) +
geom_bar(
aes(fill = Group),
stat = "identity",
position = position_dodge(width = 0.7),
width = 0.6
) +
geom_text(
aes(label = round(Score, 2), group = Group),
position = position_dodge(width = 0.7),
vjust = -0.4,
size = 3.8
) +
geom_line(
data = df,
aes(x = Category, y = Average, group = 1),
color = "darkgreen",
linewidth = 1.2,
alpha = 0.6
) +
geom_point(
data = df,
aes(x = Category, y = Average),
color = "darkgreen",
size = 3.2,
alpha = 0.6
) +
scale_fill_manual(
values = c(
"International" = "#2C7FB8",
"Domestic"      = "#D62728"
)
) +
labs(
title = "AI Ethics, Trust, and Value Perception",
y = "Average Score",
x = ""
) +
theme_minimal() +
theme(
axis.text.x = element_text(size = 10),
axis.text.y = element_text(size = 15, face = "bold"),
axis.title.y = element_text(size = 18, face = "bold"),
plot.title = element_text(
hjust = 0.5,
size = 26,
face = "bold"
),
legend.position = "none"
) +
coord_cartesian(ylim = c(3.5, 7))
table_data <- data.frame(
Group = c("International", "Domestic", "Average"),
rbind(
round(international_scores, 2),
round(domestic_scores, 2),
round(avg_scores, 2)
)
)
colnames(table_data)[2:ncol(table_data)] <- categories
n_cols <- ncol(table_data)
n_rows <- nrow(table_data)
fill_matrix <- matrix(
c(
rep("#2C7FB8", n_cols),
rep("#D62728", n_cols),
rep("darkgreen", n_cols)
),
nrow = n_rows,
byrow = TRUE
)
table_grob <- tableGrob(
table_data,
rows = NULL,
theme = ttheme_minimal(
core = list(
fg_params = list(col = "white", fontsize = 13),
bg_params = list(fill = fill_matrix)
),
colhead = list(
fg_params = list(fontface = "bold", fontsize = 11)
)
)
)
grid.arrange(
p,
table_grob,
ncol = 1,
heights = c(4, 1.4)
)
